{
    "sura": 101,
    "nombre_versets": 11,
    "versets": [
        {
            "index": 6158,
            "sura": 101,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ الْقَارِعَةُ",
            "text_fr": "Le Fracassant !"
        },
        {
            "index": 6159,
            "sura": 101,
            "aya": 2,
            "text": "مَا الْقَارِعَةُ",
            "text_fr": "Qu'est-ce que le Fracassant?"
        },
        {
            "index": 6160,
            "sura": 101,
            "aya": 3,
            "text": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ",
            "text_fr": "Et que sais-tu, qu'est-ce que le Fracassant?!"
        },
        {
            "index": 6161,
            "sura": 101,
            "aya": 4,
            "text": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
            "text_fr": "Le Jour où les hommes seront comme les papillons dispersés,"
        },
        {
            "index": 6162,
            "sura": 101,
            "aya": 5,
            "text": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوشِ",
            "text_fr": "et que les montagnes seront comme de la laine cardée."
        },
        {
            "index": 6163,
            "sura": 101,
            "aya": 6,
            "text": "فَأَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ",
            "text_fr": "Quant à celui dont les pesées auront du poids,"
        },
        {
            "index": 6164,
            "sura": 101,
            "aya": 7,
            "text": "فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ",
            "text_fr": "il sera en une vie satisfaite."
        },
        {
            "index": 6165,
            "sura": 101,
            "aya": 8,
            "text": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ",
            "text_fr": "Et quant à celui dont les pesées seront légères,"
        },
        {
            "index": 6166,
            "sura": 101,
            "aya": 9,
            "text": "فَأُمُّهُ هَاوِيَةٌ",
            "text_fr": "sa tête alors sera précipitée."
        },
        {
            "index": 6167,
            "sura": 101,
            "aya": 10,
            "text": "وَمَا أَدْرَاكَ مَا هِيَهْ",
            "text_fr": "Et qu'en sais-tu, ce que c'est ?!"
        },
        {
            "index": 6168,
            "sura": 101,
            "aya": 11,
            "text": "نَارٌ حَامِيَةٌ",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Un Feu brûlant. —A ——"
        }
    ]
}