{
    "sura": 81,
    "nombre_versets": 29,
    "versets": [
        {
            "index": 5801,
            "sura": 81,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ إِذَا الشَّمْسُ كُوِّرَتْ",
            "text_fr": "Quand le soleil sera enroulé,"
        },
        {
            "index": 5802,
            "sura": 81,
            "aya": 2,
            "text": "وَإِذَا النُّجُومُ انْكَدَرَتْ",
            "text_fr": "et quand les étoiles disparaîtront,"
        },
        {
            "index": 5803,
            "sura": 81,
            "aya": 3,
            "text": "وَإِذَا الْجِبَالُ سُيِّرَتْ",
            "text_fr": "et quand les montagnes seront déplacées,"
        },
        {
            "index": 5804,
            "sura": 81,
            "aya": 4,
            "text": "وَإِذَا الْعِشَارُ عُطِّلَتْ",
            "text_fr": "et quand les chamelles deviendront stériles,"
        },
        {
            "index": 5805,
            "sura": 81,
            "aya": 5,
            "text": "وَإِذَا الْوُحُوشُ حُشِرَتْ",
            "text_fr": "et quand les fauves seront rassemblés,"
        },
        {
            "index": 5806,
            "sura": 81,
            "aya": 6,
            "text": "وَإِذَا الْبِحَارُ سُجِّرَتْ",
            "text_fr": "et quand les mers seront enflammées,"
        },
        {
            "index": 5807,
            "sura": 81,
            "aya": 7,
            "text": "وَإِذَا النُّفُوسُ زُوِّجَتْ",
            "text_fr": "et quand les âmes seront unies aux corps,"
        },
        {
            "index": 5808,
            "sura": 81,
            "aya": 8,
            "text": "وَإِذَا الْمَوْءُودَةُ سُئِلَتْ",
            "text_fr": "et quand l'enterrée vivante sera questionnée :"
        },
        {
            "index": 5809,
            "sura": 81,
            "aya": 9,
            "text": "بِأَيِّ ذَنْبٍ قُتِلَتْ",
            "text_fr": "« Pour quelle faute a-t-elle été tuée ? »"
        },
        {
            "index": 5810,
            "sura": 81,
            "aya": 10,
            "text": "وَإِذَا الصُّحُفُ نُشِرَتْ",
            "text_fr": "Et quand les registres seront ouverts,"
        },
        {
            "index": 5811,
            "sura": 81,
            "aya": 11,
            "text": "وَإِذَا السَّمَاءُ كُشِطَتْ",
            "text_fr": "et quand le ciel sera ôté,"
        },
        {
            "index": 5812,
            "sura": 81,
            "aya": 12,
            "text": "وَإِذَا الْجَحِيمُ سُعِّرَتْ",
            "text_fr": "et quand la Géhenne sera embrasée,"
        },
        {
            "index": 5813,
            "sura": 81,
            "aya": 13,
            "text": "وَإِذَا الْجَنَّةُ أُزْلِفَتْ",
            "text_fr": "et quand le Paradis sera rapproché,"
        },
        {
            "index": 5814,
            "sura": 81,
            "aya": 14,
            "text": "عَلِمَتْ نَفْسٌ مَا أَحْضَرَتْ",
            "text_fr": "chaque âme saura ce qu'elle a fait !"
        },
        {
            "index": 5815,
            "sura": 81,
            "aya": 15,
            "text": "فَلَا أُقْسِمُ بِالْخُنَّسِ",
            "text_fr": "Je Jure formellement par les planètes qui s'éclipsent,"
        },
        {
            "index": 5816,
            "sura": 81,
            "aya": 16,
            "text": "الْجَوَارِ الْكُنَّسِ",
            "text_fr": "qui courent, qui disparaissent ;"
        },
        {
            "index": 5817,
            "sura": 81,
            "aya": 17,
            "text": "وَاللَّيْلِ إِذَا عَسْعَسَ",
            "text_fr": "et par la nuit quand elle envahit ;"
        },
        {
            "index": 5818,
            "sura": 81,
            "aya": 18,
            "text": "وَالصُّبْحِ إِذَا تَنَفَّسَ",
            "text_fr": "et par le matin quand il éclôt ;"
        },
        {
            "index": 5819,
            "sura": 81,
            "aya": 19,
            "text": "إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ",
            "text_fr": "c'est la parole d'un noble Messager,* * 19 Allusion faite à l'Ange Gabriel —j"
        },
        {
            "index": 5820,
            "sura": 81,
            "aya": 20,
            "text": "ذِي قُوَّةٍ عِنْدَ ذِي الْعَرْشِ مَكِينٍ",
            "text_fr": "doué de pouvoir auprès du Détenteur du Trône, jouissant d'une autorité:"
        },
        {
            "index": 5821,
            "sura": 81,
            "aya": 21,
            "text": "مُطَاعٍ ثَمَّ أَمِينٍ",
            "text_fr": "il est obéi, là-bas, fidèle à la Révélation."
        },
        {
            "index": 5822,
            "sura": 81,
            "aya": 22,
            "text": "وَمَا صَاحِبُكُمْ بِمَجْنُونٍ",
            "text_fr": "Et votre Compagnon n'est point fou !"
        },
        {
            "index": 5823,
            "sura": 81,
            "aya": 23,
            "text": "وَلَقَدْ رَآهُ بِالْأُفُقِ الْمُبِينِ",
            "text_fr": "Et il l'a vu, en fait, à l'horizon évident."
        },
        {
            "index": 5824,
            "sura": 81,
            "aya": 24,
            "text": "وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ",
            "text_fr": "Il n'est point tenace de l'Occulte* ,"
        },
        {
            "index": 5825,
            "sura": 81,
            "aya": 25,
            "text": "وَمَا هُوَ بِقَوْلِ شَيْطَانٍ رَجِيمٍ",
            "text_fr": "Et ce n'est point les paroles* d'un démon lapidé."
        },
        {
            "index": 5826,
            "sura": 81,
            "aya": 26,
            "text": "فَأَيْنَ تَذْهَبُونَ",
            "text_fr": "Où donc allez-vous ?"
        },
        {
            "index": 5827,
            "sura": 81,
            "aya": 27,
            "text": "إِنْ هُوَ إِلَّا ذِكْرٌ لِلْعَالَمِينَ",
            "text_fr": "Ce n'est qu'un Rappel aux Univers,"
        },
        {
            "index": 5828,
            "sura": 81,
            "aya": 28,
            "text": "لِمَنْ شَاءَ مِنْكُمْ أَنْ يَسْتَقِيمَ",
            "text_fr": "à quiconque d'entre vous qui voudrait suivre la rectitude."
        },
        {
            "index": 5829,
            "sura": 81,
            "aya": 29,
            "text": "وَمَا تَشَاءُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ رَبُّ الْعَالَمِينَ",
            "text_fr": "— Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Et vous ne voudrez que si Allah, Seigneur des Univers, le Veut. *24 Le Prophète, car il ne garde pas avarement les choses de l'au-delà *25 Allusion faite au Qur'ân ——s H-…————"
        }
    ]
}