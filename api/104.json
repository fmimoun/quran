{
    "sura": 104,
    "nombre_versets": 9,
    "versets": [
        {
            "index": 6180,
            "sura": 104,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ وَيْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ",
            "text_fr": "Malheur à tout diffamateur médisant :"
        },
        {
            "index": 6181,
            "sura": 104,
            "aya": 2,
            "text": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ",
            "text_fr": "qui a amassé des richesses et les a comptées."
        },
        {
            "index": 6182,
            "sura": 104,
            "aya": 3,
            "text": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ",
            "text_fr": "Il pense que ses richesses l'ont rendu immortel."
        },
        {
            "index": 6183,
            "sura": 104,
            "aya": 4,
            "text": "كَلَّا ۖ لَيُنْبَذَنَّ فِي الْحُطَمَةِ",
            "text_fr": "Non ! Il sera sûrement jeté dans la Broyeuse* ."
        },
        {
            "index": 6184,
            "sura": 104,
            "aya": 5,
            "text": "وَمَا أَدْرَاكَ مَا الْحُطَمَةُ",
            "text_fr": "Et que sais-tu, qu'est-ce que la Broyeuse ?"
        },
        {
            "index": 6185,
            "sura": 104,
            "aya": 6,
            "text": "نَارُ اللَّهِ الْمُوقَدَةُ",
            "text_fr": "Le Feu d'Allah qui flambe,"
        },
        {
            "index": 6186,
            "sura": 104,
            "aya": 7,
            "text": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ",
            "text_fr": "qui pénètre jusqu'aux cœurs !"
        },
        {
            "index": 6187,
            "sura": 104,
            "aya": 8,
            "text": "إِنَّهَا عَلَيْهِمْ مُؤْصَدَةٌ",
            "text_fr": "Il sera clos sur eux,"
        },
        {
            "index": 6188,
            "sura": 104,
            "aya": 9,
            "text": "فِي عَمَدٍ مُمَدَّدَةٍ",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux en des colonnes élancées. *4 Un des attributs de l'Enfer. ——————Ç 765 H—"
        }
    ]
}