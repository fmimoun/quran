            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ أَلْهَاكُمُ التَّكَاثُرُ",
            "text_fr": "L'ostentation des richesses vous a distraits"
        },
        {
            "index": 6170,
            "sura": 102,
            "aya": 2,
            "text": "حَتَّىٰ زُرْتُمُ الْمَقَابِرَ",
            "text_fr": "au point que vous avez visité les tombeaux !*"
        },
        {
            "index": 6171,
            "sura": 102,
            "aya": 3,
            "text": "كَلَّا سَوْفَ تَعْلَمُونَ",
            "text_fr": "Non. Bientôt vous saurez."
        },
        {
            "index": 6172,
            "sura": 102,
            "aya": 4,
            "text": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
            "text_fr": "Ensuite, non ! Bientôt vous saurez."
        },
        {
            "index": 6173,
            "sura": 102,
            "aya": 5,
            "text": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ",
            "text_fr": "Non. Si vous saviez la science de l'évidence,"
        },
        {
            "index": 6174,
            "sura": 102,
            "aya": 6,
            "text": "لَتَرَوُنَّ الْجَحِيمَ",
            "text_fr": "vous verriez sûrement la Géhenne."
        },
        {
            "index": 6175,
            "sura": 102,
            "aya": 7,
            "text": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ",
            "text_fr": "Puis, vous la verriez sûrement en toute évidence."
        },
        {
            "index": 6176,
            "sura": 102,
            "aya": 8,
            "text": "ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Ensuite, on vous interrogera sûrement, ce Jour-là, sur les félicités. *2 \/ Au temps préislamique, les arabes se vantaient de leur nombre, vivants ou morts, et comptaient les morts dans leurs tombes. — 0H—"
