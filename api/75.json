{
    "sura": 75,
    "nombre_versets": 40,
    "versets": [
        {
            "index": 5552,
            "sura": 75,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ",
            "text_fr": "Je Jure formellement par le Jour de la Résurrection !"
        },
        {
            "index": 5553,
            "sura": 75,
            "aya": 2,
            "text": "وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ",
            "text_fr": "Et Je Jure formellement par la conscience en blâme continuellement !"
        },
        {
            "index": 5554,
            "sura": 75,
            "aya": 3,
            "text": "أَيَحْسَبُ الْإِنْسَانُ أَلَّنْ نَجْمَعَ عِظَامَهُ",
            "text_fr": "L'homme pense-t-il que Nous n'Allons pas Rassembler ses os ?"
        },
        {
            "index": 5555,
            "sura": 75,
            "aya": 4,
            "text": "بَلَىٰ قَادِرِينَ عَلَىٰ أَنْ نُسَوِّيَ بَنَانَهُ",
            "text_fr": "Mais oui! Nous sommes Capable de Parfaire son empreinte !"
        },
        {
            "index": 5556,
            "sura": 75,
            "aya": 5,
            "text": "بَلْ يُرِيدُ الْإِنْسَانُ لِيَفْجُرَ أَمَامَهُ",
            "text_fr": "Plutôt, l'homme voudrait être impudent devant Lui !"
        },
        {
            "index": 5557,
            "sura": 75,
            "aya": 6,
            "text": "يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ",
            "text_fr": "1l demande : « A quand le Jour de la Résurrection ?! »"
        },
        {
            "index": 5558,
            "sura": 75,
            "aya": 7,
            "text": "فَإِذَا بَرِقَ الْبَصَرُ",
            "text_fr": "Lorsque la vue aberrera,"
        },
        {
            "index": 5559,
            "sura": 75,
            "aya": 8,
            "text": "وَخَسَفَ الْقَمَرُ",
            "text_fr": "et que la lune s'éclipsera,"
        },
        {
            "index": 5560,
            "sura": 75,
            "aya": 9,
            "text": "وَجُمِعَ الشَّمْسُ وَالْقَمَرُ",
            "text_fr": "et que le soleil et la lune seront réunis,"
        },
        {
            "index": 5561,
            "sura": 75,
            "aya": 10,
            "text": "يَقُولُ الْإِنْسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ",
            "text_fr": "l'homme dira ce Jour-là : « Où est l'échappatoire ? »"
        },
        {
            "index": 5562,
            "sura": 75,
            "aya": 11,
            "text": "كَلَّا لَا وَزَرَ",
            "text_fr": "Non ! Pas de refuge :"
        },
        {
            "index": 5563,
            "sura": 75,
            "aya": 12,
            "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ",
            "text_fr": "vers ton Seigneur, ce Jour-là, sera le séjour."
        },
        {
            "index": 5564,
            "sura": 75,
            "aya": 13,
            "text": "يُنَبَّأُ الْإِنْسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ",
            "text_fr": "On informera l'homme, ce Jour-là, de ce qu'il a fait ou laissé."
        },
        {
            "index": 5565,
            "sura": 75,
            "aya": 14,
            "text": "بَلِ الْإِنْسَانُ عَلَىٰ نَفْسِهِ بَصِيرَةٌ",
            "text_fr": "Plutôt, l'homme aura une clairvoyance sur lui-même,"
        },
        {
            "index": 5566,
            "sura": 75,
            "aya": 15,
            "text": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُ",
            "text_fr": "même s'il présente ses excuses. ——"
        },
        {
            "index": 5567,
            "sura": 75,
            "aya": 16,
            "text": "لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ",
            "text_fr": "N'en remue point ta langue pour hâter son obtention* ."
        },
        {
            "index": 5568,
            "sura": 75,
            "aya": 17,
            "text": "إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ",
            "text_fr": "C'est à Nous qu'incombe son assemblage et sa lecture."
        },
        {
            "index": 5569,
            "sura": 75,
            "aya": 18,
            "text": "فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ",
            "text_fr": "Quand Nous le Lisons, suis alors sa lecture."
        },
        {
            "index": 5570,
            "sura": 75,
            "aya": 19,
            "text": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ",
            "text_fr": "Ensuite, c'est à Nous qu'incombe son explication."
        },
        {
            "index": 5571,
            "sura": 75,
            "aya": 20,
            "text": "كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ",
            "text_fr": "Non ! Plutôt, vous aimez l'éphémère,"
        },
        {
            "index": 5572,
            "sura": 75,
            "aya": 21,
            "text": "وَتَذَرُونَ الْآخِرَةَ",
            "text_fr": "et vous délaissez la vie Future."
        },
        {
            "index": 5573,
            "sura": 75,
            "aya": 22,
            "text": "وُجُوهٌ يَوْمَئِذٍ نَاضِرَةٌ",
            "text_fr": "Ce Jour-là : des visages resplendissants,"
        },
        {
            "index": 5574,
            "sura": 75,
            "aya": 23,
            "text": "إِلَىٰ رَبِّهَا نَاظِرَةٌ",
            "text_fr": "regardant vers leur Seigneur,"
        },
        {
            "index": 5575,
            "sura": 75,
            "aya": 24,
            "text": "وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ",
            "text_fr": "et ce Jour-là : des visages assombris."
        },
        {
            "index": 5576,
            "sura": 75,
            "aya": 25,
            "text": "تَظُنُّ أَنْ يُفْعَلَ بِهَا فَاقِرَةٌ",
            "text_fr": "S'attendant à une catastrophe qui leur scierait le dos !"
        },
        {
            "index": 5577,
            "sura": 75,
            "aya": 26,
            "text": "كَلَّا إِذَا بَلَغَتِ التَّرَاقِيَ",
            "text_fr": "Mais non ! Quand elle atteindra les clavicules,"
        },
        {
            "index": 5578,
            "sura": 75,
            "aya": 27,
            "text": "وَقِيلَ مَنْ ۜ رَاقٍ",
            "text_fr": "et que l'on dira : « Qui est incantateur ? »"
        },
        {
            "index": 5579,
            "sura": 75,
            "aya": 28,
            "text": "وَظَنَّ أَنَّهُ الْفِرَاقُ",
            "text_fr": "et qu'il pense que c'est la séparation,"
        },
        {
            "index": 5580,
            "sura": 75,
            "aya": 29,
            "text": "وَالْتَفَّتِ السَّاقُ بِالسَّاقِ",
            "text_fr": "et que la jambe se crispe sur la jambe,"
        },
        {
            "index": 5581,
            "sura": 75,
            "aya": 30,
            "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ الْمَسَاقُ",
            "text_fr": "vers ton Seigneur, ce Jour-là, sera la poussée en avant :"
        },
        {
            "index": 5582,
            "sura": 75,
            "aya": 31,
            "text": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
            "text_fr": "Il n'a eu alors ni foi, ni il n'a prié,"
        },
        {
            "index": 5583,
            "sura": 75,
            "aya": 32,
            "text": "وَلَـٰكِنْ كَذَّبَ وَتَوَلَّىٰ",
            "text_fr": "mais il a démenti et s'écarta."
        },
        {
            "index": 5584,
            "sura": 75,
            "aya": 33,
            "text": "ثُمَّ ذَهَبَ إِلَىٰ أَهْلِهِ يَتَمَطَّىٰ",
            "text_fr": "Ensuite il alla chez les siens se pavanant."
        },
        {
            "index": 5585,
            "sura": 75,
            "aya": 34,
            "text": "أَوْلَىٰ لَكَ فَأَوْلَىٰ",
            "text_fr": "Malheur à toi, et malheur !"
        },
        {
            "index": 5586,
            "sura": 75,
            "aya": 35,
            "text": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰ",
            "text_fr": "ensuite, malheur à toi, et malheur !*"
        },
        {
            "index": 5587,
            "sura": 75,
            "aya": 36,
            "text": "أَيَحْسَبُ الْإِنْسَانُ أَنْ يُتْرَكَ سُدًى",
            "text_fr": "L'être humain pense-t-il qu'il sera laissé sans but ?!"
        },
        {
            "index": 5588,
            "sura": 75,
            "aya": 37,
            "text": "أَلَمْ يَكُ نُطْفَةً مِنْ مَنِيٍّ يُمْنَىٰ",
            "text_fr": "Ne fut-il pas une nutfah d'un sperme éjaculé ?"
        },
        {
            "index": 5589,
            "sura": 75,
            "aya": 38,
            "text": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ",
            "text_fr": "Ensuite il fut une ‘alaqah, alors Il A Créé et Il A Parfait ?"
        },
        {
            "index": 5590,
            "sura": 75,
            "aya": 39,
            "text": "فَجَعَلَ مِنْهُ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنْثَىٰ",
            "text_fr": "Et Il en Fit le couple : le mâle et la femelle ?"
        },
        {
            "index": 5591,
            "sura": 75,
            "aya": 40,
            "text": "أَلَيْسَ ذَٰلِكَ بِقَادِرٍ عَلَىٰ أَنْ يُحْيِيَ الْمَوْتَىٰ",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Celui-là n'est-II pas Capable de Faire vivre les morts ?! *16 Allusion faite au Qur'än #35 C'est répété dans le texte. Ç ns H—"
        }
    ]
}