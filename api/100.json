    "versets": [
        {
            "index": 6147,
            "sura": 100,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ وَالْعَادِيَاتِ ضَبْحًا",
            "text_fr": "Par les destriers en sueur,"
        },
        {
            "index": 6148,
            "sura": 100,
            "aya": 2,
            "text": "فَالْمُورِيَاتِ قَدْحًا",
            "text_fr": "puis, par ceux qui font jaillir des étincelles,"
        },
        {
            "index": 6149,
            "sura": 100,
            "aya": 3,
            "text": "فَالْمُغِيرَاتِ صُبْحًا",
            "text_fr": "puis, par ceux qui foncent au matin,"
        },
        {
            "index": 6150,
            "sura": 100,
            "aya": 4,
            "text": "فَأَثَرْنَ بِهِ نَقْعًا",
            "text_fr": "en y soulevant une poussière,"
        },
        {
            "index": 6151,
            "sura": 100,
            "aya": 5,
            "text": "فَوَسَطْنَ بِهِ جَمْعًا",
            "text_fr": "et en pénétrant avec au milieu des troupes :"
        },
        {
            "index": 6152,
            "sura": 100,
            "aya": 6,
            "text": "إِنَّ الْإِنْسَانَ لِرَبِّهِ لَكَنُودٌ",
            "text_fr": "l'être humain est sûrement ingrat envers son Seigneur !"
        },
        {
            "index": 6153,
            "sura": 100,
            "aya": 7,
            "text": "وَإِنَّهُ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ",
            "text_fr": "Etil est sûrement témoin de cela."
        },
        {
            "index": 6154,
            "sura": 100,
            "aya": 8,
            "text": "وَإِنَّهُ لِحُبِّ الْخَيْرِ لَشَدِيدٌ",
            "text_fr": "Et de l'amour des richesses, il est sûrement avide !"
        },
        {
            "index": 6155,
            "sura": 100,
            "aya": 9,
            "text": "أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ",
            "text_fr": "Ne sait-il donc pas que lorsque ce qui est dans les tombes sera bouleversé,"
        },
        {
            "index": 6156,
            "sura": 100,
            "aya": 10,
            "text": "وَحُصِّلَ مَا فِي الصُّدُورِ",
            "text_fr": "et que ce qui est dans les cœurs sera dévoilé,"
        },
        {
            "index": 6157,
            "sura": 100,
            "aya": 11,
            "text": "إِنَّ رَبَّهُمْ بِهِمْ يَوْمَئِذٍ لَخَبِيرٌ",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux que leur Seigneur, ce Jour-là, Est sûrement Omnicon- naissant ? —‘{map—Œ—ÆŒ—"
        }
    ]
}