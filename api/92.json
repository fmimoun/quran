{
    "sura": 92,
    "nombre_versets": 21,
    "versets": [
        {
            "index": 6059,
            "sura": 92,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ وَاللَّيْلِ إِذَا يَغْشَىٰ",
            "text_fr": "Par la nuit quand elle enveloppe,"
        },
        {
            "index": 6060,
            "sura": 92,
            "aya": 2,
            "text": "وَالنَّهَارِ إِذَا تَجَلَّىٰ",
            "text_fr": "et par le jour quand il s'éclaire,"
        },
        {
            "index": 6061,
            "sura": 92,
            "aya": 3,
            "text": "وَمَا خَلَقَ الذَّكَرَ وَالْأُنْثَىٰ",
            "text_fr": "et par Celui qui A Créé le mâle et la femelle,"
        },
        {
            "index": 6062,
            "sura": 92,
            "aya": 4,
            "text": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
            "text_fr": "certes, vos efforts sont sûrement variés* ."
        },
        {
            "index": 6063,
            "sura": 92,
            "aya": 5,
            "text": "فَأَمَّا مَنْ أَعْطَىٰ وَاتَّقَىٰ",
            "text_fr": "Quant à celui qui a donné, et a été pieux,"
        },
        {
            "index": 6064,
            "sura": 92,
            "aya": 6,
            "text": "وَصَدَّقَ بِالْحُسْنَىٰ",
            "text_fr": "eta eu foi en (la religion) la meilleure,"
        },
        {
            "index": 6065,
            "sura": 92,
            "aya": 7,
            "text": "فَسَنُيَسِّرُهُ لِلْيُسْرَىٰ",
            "text_fr": "Nous lui Faciliterons vers l'aisée."
        },
        {
            "index": 6066,
            "sura": 92,
            "aya": 8,
            "text": "وَأَمَّا مَنْ بَخِلَ وَاسْتَغْنَىٰ",
            "text_fr": "Et quant à celui qui a lésiné, et s'en passa,"
        },
        {
            "index": 6067,
            "sura": 92,
            "aya": 9,
            "text": "وَكَذَّبَ بِالْحُسْنَىٰ",
            "text_fr": "et a démenti (la religion) la meilleure,"
        },
        {
            "index": 6068,
            "sura": 92,
            "aya": 10,
            "text": "فَسَنُيَسِّرُهُ لِلْعُسْرَىٰ",
            "text_fr": "Nous lui Faciliterons vers la plus ardue."
        },
        {
            "index": 6069,
            "sura": 92,
            "aya": 11,
            "text": "وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تَرَدَّىٰ",
            "text_fr": "Et ses richesses ne lui serviront à rien quand il se perdra."
        },
        {
            "index": 6070,
            "sura": 92,
            "aya": 12,
            "text": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
            "text_fr": "C'est à Nous Seul qu'incombe la Direction,"
        },
        {
            "index": 6071,
            "sura": 92,
            "aya": 13,
            "text": "وَإِنَّ لَنَا لَلْآخِرَةَ وَالْأُولَىٰ",
            "text_fr": "et c'est de Nous Seul que dépendent la vie Future et la vie première."
        },
        {
            "index": 6072,
            "sura": 92,
            "aya": 14,
            "text": "فَأَنْذَرْتُكُمْ نَارًا تَلَظَّىٰ",
            "text_fr": "Et Je vous ai Avertis d'un Feu flambant."
        },
        {
            "index": 6073,
            "sura": 92,
            "aya": 15,
            "text": "لَا يَصْلَاهَا إِلَّا الْأَشْقَى",
            "text_fr": "N'y sera enfoncé que le plus misérable,"
        },
        {
            "index": 6074,
            "sura": 92,
            "aya": 16,
            "text": "الَّذِي كَذَّبَ وَتَوَلَّىٰ",
            "text_fr": "celui qui démentit et s'en est détourné."
        },
        {
            "index": 6075,
            "sura": 92,
            "aya": 17,
            "text": "وَسَيُجَنَّبُهَا الْأَتْقَى",
            "text_fr": "Et le plus pieux en sera écarté."
        },
        {
            "index": 6076,
            "sura": 92,
            "aya": 18,
            "text": "الَّذِي يُؤْتِي مَالَهُ يَتَزَكَّىٰ",
            "text_fr": "Celui qui donne ses richesses pour s'épurer, *4 Cela désigne que les efforts de l'homme sont mesurés d'après le degré d'obédience à Allah, mais la plupart des gens n'y prêtent pas attention. —…j Sürahs 92 Partie 30"
        },
        {
            "index": 6077,
            "sura": 92,
            "aya": 19,
            "text": "وَمَا لِأَحَدٍ عِنْدَهُ مِنْ نِعْمَةٍ تُجْزَىٰ",
            "text_fr": "et ne s'attend à la récompense de personne."
        },
        {
            "index": 6078,
            "sura": 92,
            "aya": 20,
            "text": "إِلَّا ابْتِغَاءَ وَجْهِ رَبِّهِ الْأَعْلَىٰ",
            "text_fr": "Rien que l'aspiration de voir la Face de son Seigneur, le Plus-Haut."
        },
        {
            "index": 6079,
            "sura": 92,
            "aya": 21,
            "text": "وَلَسَوْفَ يَرْضَىٰ",
            "text_fr": "— Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Et il sera sûrement satisfait. ——"
        }
    ]
}