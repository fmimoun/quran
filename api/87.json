{
    "sura": 87,
    "nombre_versets": 19,
    "versets": [
        {
            "index": 5949,
            "sura": 87,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى",
            "text_fr": "Exalte le Nom de ton Seigneur, Le Plus-Haut,"
        },
        {
            "index": 5950,
            "sura": 87,
            "aya": 2,
            "text": "الَّذِي خَلَقَ فَسَوَّىٰ",
            "text_fr": "Celui qui A Créé et À Parfait,"
        },
        {
            "index": 5951,
            "sura": 87,
            "aya": 3,
            "text": "وَالَّذِي قَدَّرَ فَهَدَىٰ",
            "text_fr": "et Celui qui A Résolu et A Guidé,"
        },
        {
            "index": 5952,
            "sura": 87,
            "aya": 4,
            "text": "وَالَّذِي أَخْرَجَ الْمَرْعَىٰ",
            "text_fr": "et Celui qui Fit pousser le pâturage,"
        },
        {
            "index": 5953,
            "sura": 87,
            "aya": 5,
            "text": "فَجَعَلَهُ غُثَاءً أَحْوَىٰ",
            "text_fr": "puis le Fit desséché, noirci."
        },
        {
            "index": 5954,
            "sura": 87,
            "aya": 6,
            "text": "سَنُقْرِئُكَ فَلَا تَنْسَىٰ",
            "text_fr": "Nous te Ferons réciter, tu n'oublieras donc pas,"
        },
        {
            "index": 5955,
            "sura": 87,
            "aya": 7,
            "text": "إِلَّا مَا شَاءَ اللَّهُ ۚ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىٰ",
            "text_fr": "sauf si ton Seigneur Voulait autre chose. Il Connaît le manifesté et le caché."
        },
        {
            "index": 5956,
            "sura": 87,
            "aya": 8,
            "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
            "text_fr": "Et Nous t'Assisterons pour l'aisé."
        },
        {
            "index": 5957,
            "sura": 87,
            "aya": 9,
            "text": "فَذَكِّرْ إِنْ نَفَعَتِ الذِّكْرَىٰ",
            "text_fr": "Rappelle alors quand le Rappel est utile."
        },
        {
            "index": 5958,
            "sura": 87,
            "aya": 10,
            "text": "سَيَذَّكَّرُ مَنْ يَخْشَىٰ",
            "text_fr": "Se souviendra celui qui craint,"
        },
        {
            "index": 5959,
            "sura": 87,
            "aya": 11,
            "text": "وَيَتَجَنَّبُهَا الْأَشْقَى",
            "text_fr": "et l'évitera le plus malheureux :"
        },
        {
            "index": 5960,
            "sura": 87,
            "aya": 12,
            "text": "الَّذِي يَصْلَى النَّارَ الْكُبْرَىٰ",
            "text_fr": "celui qui sera enfoncé dans le Feu le plus Grand,"
        },
        {
            "index": 5961,
            "sura": 87,
            "aya": 13,
            "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
            "text_fr": "ensuite, il n'y mourra point ni ne vivra."
        },
        {
            "index": 5962,
            "sura": 87,
            "aya": 14,
            "text": "قَدْ أَفْلَحَ مَنْ تَزَكَّىٰ",
            "text_fr": "A effectivement cultivé celui qui s'est épuré,"
        },
        {
            "index": 5963,
            "sura": 87,
            "aya": 15,
            "text": "وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّىٰ",
            "text_fr": "et psalmodia le Nom de son Seigneur puis pria."
        },
        {
            "index": 5964,
            "sura": 87,
            "aya": 16,
            "text": "بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا",
            "text_fr": "Plutôt, vous préférez la vie terrestre,"
        },
        {
            "index": 5965,
            "sura": 87,
            "aya": 17,
            "text": "وَالْآخِرَةُ خَيْرٌ وَأَبْقَىٰ",
            "text_fr": "alors que la vie Future est meilleure et plus permanente."
        },
        {
            "index": 5966,
            "sura": 87,
            "aya": 18,
            "text": "إِنَّ هَـٰذَا لَفِي الصُّحُفِ الْأُولَىٰ",
            "text_fr": "Certes, cela est sûrement dans les Livres Anciens,"
        },
        {
            "index": 5967,
            "sura": 87,
            "aya": 19,
            "text": "صُحُفِ إِبْرَاهِيمَ وَمُوسَىٰ",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux les Livres d'Abraham et de Moïse. —— H—"
        }
    ]
}