{
    "sura": 88,
    "nombre_versets": 26,
    "versets": [
        {
            "index": 5968,
            "sura": 88,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ",
            "text_fr": "Le récit du Cataclysme t'est-il parvenu ?"
        },
        {
            "index": 5969,
            "sura": 88,
            "aya": 2,
            "text": "وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ",
            "text_fr": "Des visages, ce Jour-là, seront humbles,"
        },
        {
            "index": 5970,
            "sura": 88,
            "aya": 3,
            "text": "عَامِلَةٌ نَاصِبَةٌ",
            "text_fr": "œuvrants, fatigués,"
        },
        {
            "index": 5971,
            "sura": 88,
            "aya": 4,
            "text": "تَصْلَىٰ نَارًا حَامِيَةً",
            "text_fr": "qui seront enfoncés en un Feu brûlant."
        },
        {
            "index": 5972,
            "sura": 88,
            "aya": 5,
            "text": "تُسْقَىٰ مِنْ عَيْنٍ آنِيَةٍ",
            "text_fr": "On leur donnera à boire d'une source bouillante."
        },
        {
            "index": 5973,
            "sura": 88,
            "aya": 6,
            "text": "لَيْسَ لَهُمْ طَعَامٌ إِلَّا مِنْ ضَرِيعٍ",
            "text_fr": "ls n'auront de nourriture que des épines,"
        },
        {
            "index": 5974,
            "sura": 88,
            "aya": 7,
            "text": "لَا يُسْمِنُ وَلَا يُغْنِي مِنْ جُوعٍ",
            "text_fr": "qui n'engraissent ni n'apaisent la faim."
        },
        {
            "index": 5975,
            "sura": 88,
            "aya": 8,
            "text": "وُجُوهٌ يَوْمَئِذٍ نَاعِمَةٌ",
            "text_fr": "Des visages, ce Jour-là, brillant de joie,"
        },
        {
            "index": 5976,
            "sura": 88,
            "aya": 9,
            "text": "لِسَعْيِهَا رَاضِيَةٌ",
            "text_fr": "satisfaits de leurs efforts."
        },
        {
            "index": 5977,
            "sura": 88,
            "aya": 10,
            "text": "فِي جَنَّةٍ عَالِيَةٍ",
            "text_fr": "En un Paradis élevé,"
        },
        {
            "index": 5978,
            "sura": 88,
            "aya": 11,
            "text": "لَا تَسْمَعُ فِيهَا لَاغِيَةً",
            "text_fr": "où tu n'entendras nul propos inconsidéré."
        },
        {
            "index": 5979,
            "sura": 88,
            "aya": 12,
            "text": "فِيهَا عَيْنٌ جَارِيَةٌ",
            "text_fr": "Il s'y trouve une source courante."
        },
        {
            "index": 5980,
            "sura": 88,
            "aya": 13,
            "text": "فِيهَا سُرُرٌ مَرْفُوعَةٌ",
            "text_fr": "Il s'y trouve des divans élevés,"
        },
        {
            "index": 5981,
            "sura": 88,
            "aya": 14,
            "text": "وَأَكْوَابٌ مَوْضُوعَةٌ",
            "text_fr": "et des coupes placées,"
        },
        {
            "index": 5982,
            "sura": 88,
            "aya": 15,
            "text": "وَنَمَارِقُ مَصْفُوفَةٌ",
            "text_fr": "et des coussins rangés,"
        },
        {
            "index": 5983,
            "sura": 88,
            "aya": 16,
            "text": "وَزَرَابِيُّ مَبْثُوثَةٌ",
            "text_fr": "et des tapis étalés."
        },
        {
            "index": 5984,
            "sura": 88,
            "aya": 17,
            "text": "أَفَلَا يَنْظُرُونَ إِلَى الْإِبِلِ كَيْفَ خُلِقَتْ",
            "text_fr": "N'ont-ils donc pas regardé les chameaux, comment ils furent créés ?"
        },
        {
            "index": 5985,
            "sura": 88,
            "aya": 18,
            "text": "وَإِلَى السَّمَاءِ كَيْفَ رُفِعَتْ",
            "text_fr": "Et le ciel, comment il fut élevé ?"
        },
        {
            "index": 5986,
            "sura": 88,
            "aya": 19,
            "text": "وَإِلَى الْجِبَالِ كَيْفَ نُصِبَتْ",
            "text_fr": "Et les montagnes, comment elles furent dressées ?"
        },
        {
            "index": 5987,
            "sura": 88,
            "aya": 20,
            "text": "وَإِلَى الْأَرْضِ كَيْفَ سُطِحَتْ",
            "text_fr": "Et la terre, comment elle fut nivelée ?"
        },
        {
            "index": 5988,
            "sura": 88,
            "aya": 21,
            "text": "فَذَكِّرْ إِنَّمَا أَنْتَ مُذَكِّرٌ",
            "text_fr": "Rappelle donc, tu n'es qu'un rappeleur : ——s H—"
        },
        {
            "index": 5989,
            "sura": 88,
            "aya": 22,
            "text": "لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ",
            "text_fr": "tu n'es pas un dominateur, pour eux."
        },
        {
            "index": 5990,
            "sura": 88,
            "aya": 23,
            "text": "إِلَّا مَنْ تَوَلَّىٰ وَكَفَرَ",
            "text_fr": "Sauf celui qui se détourna et devint mécréant :"
        },
        {
            "index": 5991,
            "sura": 88,
            "aya": 24,
            "text": "فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ",
            "text_fr": "Allah alors le Châtiera le châtiment le plus grand."
        },
        {
            "index": 5992,
            "sura": 88,
            "aya": 25,
            "text": "إِنَّ إِلَيْنَا إِيَابَهُمْ",
            "text_fr": "— Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux C'est vers Nous que se fera leur retour,"
        },
        {
            "index": 5993,
            "sura": 88,
            "aya": 26,
            "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْ",
            "text_fr": "Ensuite, à Nous Seul Incombe leur jugement. ——"
        }
    ]
}