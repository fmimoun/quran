{
    "sura": 86,
    "nombre_versets": 17,
    "versets": [
        {
            "index": 5932,
            "sura": 86,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ وَالسَّمَاءِ وَالطَّارِقِ",
            "text_fr": "Par le Ciel et par la Pulsatrice !"
        },
        {
            "index": 5933,
            "sura": 86,
            "aya": 2,
            "text": "وَمَا أَدْرَاكَ مَا الطَّارِقُ",
            "text_fr": "Et que sais-tu de la Pulsatrice ?"
        },
        {
            "index": 5934,
            "sura": 86,
            "aya": 3,
            "text": "النَّجْمُ الثَّاقِبُ",
            "text_fr": "C'est l'étoile perforatrice* ."
        },
        {
            "index": 5935,
            "sura": 86,
            "aya": 4,
            "text": "إِنْ كُلُّ نَفْسٍ لَمَّا عَلَيْهَا حَافِظٌ",
            "text_fr": "Certes, chaque personne a sûrement un gardien."
        },
        {
            "index": 5936,
            "sura": 86,
            "aya": 5,
            "text": "فَلْيَنْظُرِ الْإِنْسَانُ مِمَّ خُلِقَ",
            "text_fr": "Que l'homme regarde de quoi il a été créé !"
        },
        {
            "index": 5937,
            "sura": 86,
            "aya": 6,
            "text": "خُلِقَ مِنْ مَاءٍ دَافِقٍ",
            "text_fr": "1l a été créé d'une eau éjaculée,"
        },
        {
            "index": 5938,
            "sura": 86,
            "aya": 7,
            "text": "يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَالتَّرَائِبِ",
            "text_fr": "qui sort d'entre le dos (de l'homme) et les côtes (de la femme)."
        },
        {
            "index": 5939,
            "sura": 86,
            "aya": 8,
            "text": "إِنَّهُ عَلَىٰ رَجْعِهِ لَقَادِرٌ",
            "text_fr": "Quant à le ressusciter, Il en Est sûrement Tout-Puissant."
        },
        {
            "index": 5940,
            "sura": 86,
            "aya": 9,
            "text": "يَوْمَ تُبْلَى السَّرَائِرُ",
            "text_fr": "Le Jour oû les consciences seront éprouvées,"
        },
        {
            "index": 5941,
            "sura": 86,
            "aya": 10,
            "text": "فَمَا لَهُ مِنْ قُوَّةٍ وَلَا نَاصِرٍ",
            "text_fr": "il n'aura alors ni puissance ni partisan."
        },
        {
            "index": 5942,
            "sura": 86,
            "aya": 11,
            "text": "وَالسَّمَاءِ ذَاتِ الرَّجْعِ",
            "text_fr": "Par le Ciel aux cycles,"
        },
        {
            "index": 5943,
            "sura": 86,
            "aya": 12,
            "text": "وَالْأَرْضِ ذَاتِ الصَّدْعِ",
            "text_fr": "et par la terre aux fissures de végétations,"
        },
        {
            "index": 5944,
            "sura": 86,
            "aya": 13,
            "text": "إِنَّهُ لَقَوْلٌ فَصْلٌ",
            "text_fr": "c'est une parole tranchée,"
        },
        {
            "index": 5945,
            "sura": 86,
            "aya": 14,
            "text": "وَمَا هُوَ بِالْهَزْلِ",
            "text_fr": "et ce n'est point une plaisanterie."
        },
        {
            "index": 5946,
            "sura": 86,
            "aya": 15,
            "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
            "text_fr": "Eux, sûrement, ils rusent une vraie ruse,"
        },
        {
            "index": 5947,
            "sura": 86,
            "aya": 16,
            "text": "وَأَكِيدُ كَيْدًا",
            "text_fr": "et Je Planifie une vraie Planification*."
        },
        {
            "index": 5948,
            "sura": 86,
            "aya": 17,
            "text": "فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Accorde donc un délai aux mécréants, accorde leur doucement un délai. *3 C'est l'étoile à neutrons ou pulsar ( voir l'introduction p. ) *16 La ruse de la part du Créateur prend le sens de planification. —[ 741 ]—"
        }
    ]
}