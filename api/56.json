{
    "sura": 56,
    "nombre_versets": 96,
    "versets": [
        {
            "index": 4980,
            "sura": 56,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ إِذَا وَقَعَتِ الْوَاقِعَةُ",
            "text_fr": "Quand l'Événement* aura lieu,"
        },
        {
            "index": 4981,
            "sura": 56,
            "aya": 2,
            "text": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ",
            "text_fr": "il n'y a aucun démenti à son échéance."
        },
        {
            "index": 4982,
            "sura": 56,
            "aya": 3,
            "text": "خَافِضَةٌ رَافِعَةٌ",
            "text_fr": "— Abaissant (les uns), élevant (les autres)."
        },
        {
            "index": 4983,
            "sura": 56,
            "aya": 4,
            "text": "إِذَا رُجَّتِ الْأَرْضُ رَجًّا",
            "text_fr": "— Quand la terre sera secouée d'un vrai secouement,"
        },
        {
            "index": 4984,
            "sura": 56,
            "aya": 5,
            "text": "وَبُسَّتِ الْجِبَالُ بَسًّا",
            "text_fr": "et que les montagnes seront déplacées un vrai déplacement,"
        },
        {
            "index": 4985,
            "sura": 56,
            "aya": 6,
            "text": "فَكَانَتْ هَبَاءً مُنْبَثًّا",
            "text_fr": "et qu'elles deviennent poussière dispersée,"
        },
        {
            "index": 4986,
            "sura": 56,
            "aya": 7,
            "text": "وَكُنْتُمْ أَزْوَاجًا ثَلَاثَةً",
            "text_fr": "— et que vous serez trois groupes."
        },
        {
            "index": 4987,
            "sura": 56,
            "aya": 8,
            "text": "فَأَصْحَابُ الْمَيْمَنَةِ مَا أَصْحَابُ الْمَيْمَنَةِ",
            "text_fr": "Les gens de la droite, comment sont les gens de la droite ?"
        },
        {
            "index": 4988,
            "sura": 56,
            "aya": 9,
            "text": "وَأَصْحَابُ الْمَشْأَمَةِ مَا أَصْحَابُ الْمَشْأَمَةِ",
            "text_fr": "Et les gens de la gauche, comment sont les gens de la gauche ?"
        },
        {
            "index": 4989,
            "sura": 56,
            "aya": 10,
            "text": "وَالسَّابِقُونَ السَّابِقُونَ",
            "text_fr": "Et les devanciers, les devanciers :"
        },
        {
            "index": 4990,
            "sura": 56,
            "aya": 11,
            "text": "أُولَـٰئِكَ الْمُقَرَّبُونَ",
            "text_fr": "Ceux-là, les plus rapprochés d'Allah,"
        },
        {
            "index": 4991,
            "sura": 56,
            "aya": 12,
            "text": "فِي جَنَّاتِ النَّعِيمِ",
            "text_fr": "sont dans les Paradis de Félicité."
        },
        {
            "index": 4992,
            "sura": 56,
            "aya": 13,
            "text": "ثُلَّةٌ مِنَ الْأَوَّلِينَ",
            "text_fr": "Une multitude des Ancêtres,"
        },
        {
            "index": 4993,
            "sura": 56,
            "aya": 14,
            "text": "وَقَلِيلٌ مِنَ الْآخِرِينَ",
            "text_fr": "et peu nombreux des derniers,"
        },
        {
            "index": 4994,
            "sura": 56,
            "aya": 15,
            "text": "عَلَىٰ سُرُرٍ مَوْضُونَةٍ",
            "text_fr": "sur des divans minutieusement fabriqués,"
        },
        {
            "index": 4995,
            "sura": 56,
            "aya": 16,
            "text": "مُتَّكِئِينَ عَلَيْهَا مُتَقَابِلِينَ",
            "text_fr": "y seront accoudés face à face, #1 Sous-entend l'inéluctable Jour de la Résurrection et du Jugement dernier. —s pH————+#-"
        },
        {
            "index": 4996,
            "sura": 56,
            "aya": 17,
            "text": "يَطُوفُ عَلَيْهِمْ وِلْدَانٌ مُخَلَّدُونَ",
            "text_fr": "servis à la ronde par de jeunes gens éternisés,"
        },
        {
            "index": 4997,
            "sura": 56,
            "aya": 18,
            "text": "بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِنْ مَعِينٍ",
            "text_fr": "de verres, d'aiguières et de coupes d'une source intarissable."
        },
        {
            "index": 4998,
            "sura": 56,
            "aya": 19,
            "text": "لَا يُصَدَّعُونَ عَنْهَا وَلَا يُنْزِفُونَ",
            "text_fr": "Ils n'en auront ni maux de tête, ni ils ne s'enivreront,"
        },
        {
            "index": 4999,
            "sura": 56,
            "aya": 20,
            "text": "وَفَاكِهَةٍ مِمَّا يَتَخَيَّرُونَ",
            "text_fr": "et des fruits de ce qu'ils choisissent,"
        },
        {
            "index": 5000,
            "sura": 56,
            "aya": 21,
            "text": "وَلَحْمِ طَيْرٍ مِمَّا يَشْتَهُونَ",
            "text_fr": "et de la chair de volailles de ce qu'ils désirent,"
        },
        {
            "index": 5001,
            "sura": 56,
            "aya": 22,
            "text": "وَحُورٌ عِينٌ",
            "text_fr": "et des Houris aux regards chastes,"
        },
        {
            "index": 5002,
            "sura": 56,
            "aya": 23,
            "text": "كَأَمْثَالِ اللُّؤْلُؤِ الْمَكْنُونِ",
            "text_fr": "pareilles aux perles bien préservées :"
        },
        {
            "index": 5003,
            "sura": 56,
            "aya": 24,
            "text": "جَزَاءً بِمَا كَانُوا يَعْمَلُونَ",
            "text_fr": "une récompense en raison de ce qu'ils faisaient."
        },
        {
            "index": 5004,
            "sura": 56,
            "aya": 25,
            "text": "لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا",
            "text_fr": "IIs n'y entendront ni propos inconsidérés ni culpabilité :"
        },
        {
            "index": 5005,
            "sura": 56,
            "aya": 26,
            "text": "إِلَّا قِيلًا سَلَامًا سَلَامًا",
            "text_fr": "rien que : Salut ! Salut !"
        },
        {
            "index": 5006,
            "sura": 56,
            "aya": 27,
            "text": "وَأَصْحَابُ الْيَمِينِ مَا أَصْحَابُ الْيَمِينِ",
            "text_fr": "Et les gens de la droite, comment sont les gens de la droite ?"
        },
        {
            "index": 5007,
            "sura": 56,
            "aya": 28,
            "text": "فِي سِدْرٍ مَخْضُودٍ",
            "text_fr": "Parmi des jujubiers taillés,"
        },
        {
            "index": 5008,
            "sura": 56,
            "aya": 29,
            "text": "وَطَلْحٍ مَنْضُودٍ",
            "text_fr": "et des bananes superposées,"
        },
        {
            "index": 5009,
            "sura": 56,
            "aya": 30,
            "text": "وَظِلٍّ مَمْدُودٍ",
            "text_fr": "et des ombrages étendus,"
        },
        {
            "index": 5010,
            "sura": 56,
            "aya": 31,
            "text": "وَمَاءٍ مَسْكُوبٍ",
            "text_fr": "et une eau courante,"
        },
        {
            "index": 5011,
            "sura": 56,
            "aya": 32,
            "text": "وَفَاكِهَةٍ كَثِيرَةٍ",
            "text_fr": "et des fruits en abondance,"
        },
        {
            "index": 5012,
            "sura": 56,
            "aya": 33,
            "text": "لَا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ",
            "text_fr": "ni interrompus ni défendus,"
        },
        {
            "index": 5013,
            "sura": 56,
            "aya": 34,
            "text": "وَفُرُشٍ مَرْفُوعَةٍ",
            "text_fr": "et des couches élevées."
        },
        {
            "index": 5014,
            "sura": 56,
            "aya": 35,
            "text": "إِنَّا أَنْشَأْنَاهُنَّ إِنْشَاءً",
            "text_fr": "Nous Formâmes les femmes du Paradis une vraie formation,"
        },
        {
            "index": 5015,
            "sura": 56,
            "aya": 36,
            "text": "فَجَعَلْنَاهُنَّ أَبْكَارًا",
            "text_fr": "et Nous les Fîmes vierges,"
        },
        {
            "index": 5016,
            "sura": 56,
            "aya": 37,
            "text": "عُرُبًا أَتْرَابًا",
            "text_fr": "aimantes et jeunes,"
        },
        {
            "index": 5017,
            "sura": 56,
            "aya": 38,
            "text": "لِأَصْحَابِ الْيَمِينِ",
            "text_fr": "pour les gens de la droite."
        },
        {
            "index": 5018,
            "sura": 56,
            "aya": 39,
            "text": "ثُلَّةٌ مِنَ الْأَوَّلِينَ",
            "text_fr": "Une multitude des Ancêtres,"
        },
        {
            "index": 5019,
            "sura": 56,
            "aya": 40,
            "text": "وَثُلَّةٌ مِنَ الْآخِرِينَ",
            "text_fr": "et une multitude des derniers."
        },
        {
            "index": 5020,
            "sura": 56,
            "aya": 41,
            "text": "وَأَصْحَابُ الشِّمَالِ مَا أَصْحَابُ الشِّمَالِ",
            "text_fr": "Et les gens de la gauche, comment sont les gens de la — é H— gauche ?"
        },
        {
            "index": 5021,
            "sura": 56,
            "aya": 42,
            "text": "فِي سَمُومٍ وَحَمِيمٍ",
            "text_fr": "Dans des Samüms* et des eaux bouillantes."
        },
        {
            "index": 5022,
            "sura": 56,
            "aya": 43,
            "text": "وَظِلٍّ مِنْ يَحْمُومٍ",
            "text_fr": "et un ombrage de fumées noires,"
        },
        {
            "index": 5023,
            "sura": 56,
            "aya": 44,
            "text": "لَا بَارِدٍ وَلَا كَرِيمٍ",
            "text_fr": "ni frais ni bienfaiteur."
        },
        {
            "index": 5024,
            "sura": 56,
            "aya": 45,
            "text": "إِنَّهُمْ كَانُوا قَبْلَ ذَٰلِكَ مُتْرَفِينَ",
            "text_fr": "Eux, ils étaient avant cela dans l'aisance,"
        },
        {
            "index": 5025,
            "sura": 56,
            "aya": 46,
            "text": "وَكَانُوا يُصِرُّونَ عَلَى الْحِنْثِ الْعَظِيمِ",
            "text_fr": "et ils insistaient sur le péché immense,"
        },
        {
            "index": 5026,
            "sura": 56,
            "aya": 47,
            "text": "وَكَانُوا يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَإِنَّا لَمَبْعُوثُونَ",
            "text_fr": "et ils disaient: «Si nous mourions et devenions poussière et os, serions-nous vraiment ressuscités,"
        },
        {
            "index": 5027,
            "sura": 56,
            "aya": 48,
            "text": "أَوَآبَاؤُنَا الْأَوَّلُونَ",
            "text_fr": "ct même nos Ancêtres premiers ?! »."
        },
        {
            "index": 5028,
            "sura": 56,
            "aya": 49,
            "text": "قُلْ إِنَّ الْأَوَّلِينَ وَالْآخِرِينَ",
            "text_fr": "Dis : « Certes, les premiers et les derniers"
        },
        {
            "index": 5029,
            "sura": 56,
            "aya": 50,
            "text": "لَمَجْمُوعُونَ إِلَىٰ مِيقَاتِ يَوْمٍ مَعْلُومٍ",
            "text_fr": "seront sûrement rassemblés en un temps fixé, d'un Jour déterminé »."
        },
        {
            "index": 5030,
            "sura": 56,
            "aya": 51,
            "text": "ثُمَّ إِنَّكُمْ أَيُّهَا الضَّالُّونَ الْمُكَذِّبُونَ",
            "text_fr": "Ensuite vous, 6 fourvoyés démenteurs,"
        },
        {
            "index": 5031,
            "sura": 56,
            "aya": 52,
            "text": "لَآكِلُونَ مِنْ شَجَرٍ مِنْ زَقُّومٍ",
            "text_fr": "vous mangerez sûrement de l'arbre de Zaqqüm,"
        },
        {
            "index": 5032,
            "sura": 56,
            "aya": 53,
            "text": "فَمَالِئُونَ مِنْهَا الْبُطُونَ",
            "text_fr": "vous vous en remplirez alors les ventres,"
        },
        {
            "index": 5033,
            "sura": 56,
            "aya": 54,
            "text": "فَشَارِبُونَ عَلَيْهِ مِنَ الْحَمِيمِ",
            "text_fr": "et vous boirez dessus de l'eau bouillante,"
        },
        {
            "index": 5034,
            "sura": 56,
            "aya": 55,
            "text": "فَشَارِبُونَ شُرْبَ الْهِيمِ",
            "text_fr": "puis vous boirez comme boivent les chameaux assoiffés."
        },
        {
            "index": 5035,
            "sura": 56,
            "aya": 56,
            "text": "هَـٰذَا نُزُلُهُمْ يَوْمَ الدِّينِ",
            "text_fr": "Cela est leur séjour le Jour du Jugement."
        },
        {
            "index": 5036,
            "sura": 56,
            "aya": 57,
            "text": "نَحْنُ خَلَقْنَاكُمْ فَلَوْلَا تُصَدِّقُونَ",
            "text_fr": "Nous vous Avons Créés, que ne croyez-vous donc pas ?"
        },
        {
            "index": 5037,
            "sura": 56,
            "aya": 58,
            "text": "أَفَرَأَيْتُمْ مَا تُمْنُونَ",
            "text_fr": "Dites-moi donc, ce que vous éjaculez,"
        },
        {
            "index": 5038,
            "sura": 56,
            "aya": 59,
            "text": "أَأَنْتُمْ تَخْلُقُونَهُ أَمْ نَحْنُ الْخَالِقُونَ",
            "text_fr": "est-ce vous qui le créez ou bien c'est Nous le Créateur ?"
        },
        {
            "index": 5039,
            "sura": 56,
            "aya": 60,
            "text": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ الْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ",
            "text_fr": "Nous Déterminâmes la mort parmi vous, et Nous ne Serons point Empêchés"
        },
        {
            "index": 5040,
            "sura": 56,
            "aya": 61,
            "text": "عَلَىٰ أَنْ نُبَدِّلَ أَمْثَالَكُمْ وَنُنْشِئَكُمْ فِي مَا لَا تَعْلَمُونَ",
            "text_fr": "de vous Remplacer par vos semblables, et de vous Former dans un état que vous ne connaissez pas."
        },
        {
            "index": 5041,
            "sura": 56,
            "aya": 62,
            "text": "وَلَقَدْ عَلِمْتُمُ النَّشْأَةَ الْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ",
            "text_fr": "Et vous avez, en fait, connu la première formation, que ne réfléchissez-vous donc pas ?! #42 Un des noms de la Géhenne. — es H—"
        },
        {
            "index": 5042,
            "sura": 56,
            "aya": 63,
            "text": "أَفَرَأَيْتُمْ مَا تَحْرُثُونَ",
            "text_fr": "Dites-moi donc, ce que vous labourez,"
        },
        {
            "index": 5043,
            "sura": 56,
            "aya": 64,
            "text": "أَأَنْتُمْ تَزْرَعُونَهُ أَمْ نَحْنُ الزَّارِعُونَ",
            "text_fr": "est-ce vous qui le cultivez ou bien est-ce Nous le Cultivateur ?"
        },
        {
            "index": 5044,
            "sura": 56,
            "aya": 65,
            "text": "لَوْ نَشَاءُ لَجَعَلْنَاهُ حُطَامًا فَظَلْتُمْ تَفَكَّهُونَ",
            "text_fr": "Si Nous Voulions, Nous le Réduirions en débris, et vous resteriez à Répéter :"
        },
        {
            "index": 5045,
            "sura": 56,
            "aya": 66,
            "text": "إِنَّا لَمُغْرَمُونَ",
            "text_fr": "« Nous voilà endettés,"
        },
        {
            "index": 5046,
            "sura": 56,
            "aya": 67,
            "text": "بَلْ نَحْنُ مَحْرُومُونَ",
            "text_fr": "plutôt, nous voilà privés ! »"
        },
        {
            "index": 5047,
            "sura": 56,
            "aya": 68,
            "text": "أَفَرَأَيْتُمُ الْمَاءَ الَّذِي تَشْرَبُونَ",
            "text_fr": "Dites-moi donc, l'eau que vous buvez,"
        },
        {
            "index": 5048,
            "sura": 56,
            "aya": 69,
            "text": "أَأَنْتُمْ أَنْزَلْتُمُوهُ مِنَ الْمُزْنِ أَمْ نَحْنُ الْمُنْزِلُونَ",
            "text_fr": "est-ce vous qui l'avez fait tomber des nuages ou bien c'est Nous qui la Faisons tomber ?"
        },
        {
            "index": 5049,
            "sura": 56,
            "aya": 70,
            "text": "لَوْ نَشَاءُ جَعَلْنَاهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ",
            "text_fr": "Si Nous Voulions, Nous la Ferions salée; que n'êtes- vous donc pas reconnaissants !"
        },
        {
            "index": 5050,
            "sura": 56,
            "aya": 71,
            "text": "أَفَرَأَيْتُمُ النَّارَ الَّتِي تُورُونَ",
            "text_fr": "Dites-moi donc, le feu que vous allumez,"
        },
        {
            "index": 5051,
            "sura": 56,
            "aya": 72,
            "text": "أَأَنْتُمْ أَنْشَأْتُمْ شَجَرَتَهَا أَمْ نَحْنُ الْمُنْشِئُونَ",
            "text_fr": "est-ce vous qui avez formé son arbre ou bien c'est Nous le Formateur ?"
        },
        {
            "index": 5052,
            "sura": 56,
            "aya": 73,
            "text": "نَحْنُ جَعَلْنَاهَا تَذْكِرَةً وَمَتَاعًا لِلْمُقْوِينَ",
            "text_fr": "Nous l'Avons Fait une remémoration et une utilité pour ceux qui en ont besoin."
        },
        {
            "index": 5053,
            "sura": 56,
            "aya": 74,
            "text": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ",
            "text_fr": "Exalte donc le Nom de ton Seigneur le Grandiose."
        },
        {
            "index": 5054,
            "sura": 56,
            "aya": 75,
            "text": "فَلَا أُقْسِمُ بِمَوَاقِعِ النُّجُومِ",
            "text_fr": "Je Jure formellement* par les positions des étoiles !"
        },
        {
            "index": 5055,
