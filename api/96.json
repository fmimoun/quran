{
    "sura": 96,
    "nombre_versets": 19,
    "versets": [
        {
            "index": 6107,
            "sura": 96,
            "aya": 1,
            "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ",
            "text_fr": "Lis, au nom de ton Seigneur, Celui qui A Créé."
        },
        {
            "index": 6108,
            "sura": 96,
            "aya": 2,
            "text": "خَلَقَ الْإِنْسَانَ مِنْ عَلَقٍ",
            "text_fr": "Il A Créé l'homme de ‘alaq*."
        },
        {
            "index": 6109,
            "sura": 96,
            "aya": 3,
            "text": "اقْرَأْ وَرَبُّكَ الْأَكْرَمُ",
            "text_fr": "Lis, ton Seigneur Est le Plus-Généreux,"
        },
        {
            "index": 6110,
            "sura": 96,
            "aya": 4,
            "text": "الَّذِي عَلَّمَ بِالْقَلَمِ",
            "text_fr": "Celui qui A Enseigné par le Calame."
        },
        {
            "index": 6111,
            "sura": 96,
            "aya": 5,
            "text": "عَلَّمَ الْإِنْسَانَ مَا لَمْ يَعْلَمْ",
            "text_fr": "1l Enseigna à l'homme ce qu'il ne savait pas."
        },
        {
            "index": 6112,
            "sura": 96,
            "aya": 6,
            "text": "كَلَّا إِنَّ الْإِنْسَانَ لَيَطْغَىٰ",
            "text_fr": "Non ! Certes, l'homme outrepasse (ses limites) sûrement,"
        },
        {
            "index": 6113,
            "sura": 96,
            "aya": 7,
            "text": "أَنْ رَآهُ اسْتَغْنَىٰ",
            "text_fr": "quand il se voit dans l'aisance."
        },
        {
            "index": 6114,
            "sura": 96,
            "aya": 8,
            "text": "إِنَّ إِلَىٰ رَبِّكَ الرُّجْعَىٰ",
            "text_fr": "Certes, c'est vers ton Seigneur que sera le retour."
        },
        {
            "index": 6115,
            "sura": 96,
            "aya": 9,
            "text": "أَرَأَيْتَ الَّذِي يَنْهَىٰ",
            "text_fr": "Dis-moi donc, celui qui empêche"
        },
        {
            "index": 6116,
            "sura": 96,
            "aya": 10,
            "text": "عَبْدًا إِذَا صَلَّىٰ",
            "text_fr": "un esclave quand il prie !"
        },
        {
            "index": 6117,
            "sura": 96,
            "aya": 11,
            "text": "أَرَأَيْتَ إِنْ كَانَ عَلَى الْهُدَىٰ",
            "text_fr": "Dis-moi, s'il suit la direction infaillible,"
        },
        {
            "index": 6118,
            "sura": 96,
            "aya": 12,
            "text": "أَوْ أَمَرَ بِالتَّقْوَىٰ",
            "text_fr": "ou s'il a commandé la Piété !"
        },
        {
            "index": 6119,
            "sura": 96,
            "aya": 13,
            "text": "أَرَأَيْتَ إِنْ كَذَّبَ وَتَوَلَّىٰ",
            "text_fr": "Dis-moi, quand il démentit et se détourna,"
        },
        {
            "index": 6120,
            "sura": 96,
            "aya": 14,
            "text": "أَلَمْ يَعْلَمْ بِأَنَّ اللَّهَ يَرَىٰ",
            "text_fr": "Ne savait-il pas qu'Allah Voit ?!"
        },
        {
            "index": 6121,
            "sura": 96,
            "aya": 15,
            "text": "كَلَّا لَئِنْ لَمْ يَنْتَهِ لَنَسْفَعًا بِالنَّاصِيَةِ",
            "text_fr": "Non ! S'il n'en finit pas Nous le Saisirons sûrement par le toupet,"
        },
        {
            "index": 6122,
            "sura": 96,
            "aya": 16,
            "text": "نَاصِيَةٍ كَاذِبَةٍ خَاطِئَةٍ",
            "text_fr": "toupet menteur, pécheur."
        },
        {
            "index": 6123,
            "sura": 96,
            "aya": 17,
            "text": "فَلْيَدْعُ نَادِيَهُ",
            "text_fr": "Qu'il appelle alors son conseil,"
        },
        {
            "index": 6124,
            "sura": 96,
            "aya": 18,
            "text": "سَنَدْعُ الزَّبَانِيَةَ",
            "text_fr": "Nous Appellerons les Anges sévéres."
        },
        {
            "index": 6125,
            "sura": 96,
            "aya": 19,
            "text": "كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبْ ۩",
            "text_fr": "Versets Au Nom d'Allah, le Miséricordeur, le Miséricordieux Non ! Ne lui obéis point. Prosterne-toi et rappmchcäoi.ﬂ *2 Voirnote S.22, v.5 —j"
        }
    ]
}